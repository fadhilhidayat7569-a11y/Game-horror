import pygame
import random

# Inisialisasi
pygame.init()
WIDTH, HEIGHT = 800, 600
screen = pygame.display.set_mode((WIDTH, HEIGHT))
pygame.display.set_caption("Niskala: Gerbang Jagat Lelembut - Prototype")

# Warna
BLACK = (0, 0, 0)
WHITE = (255, 255, 255)
RED = (200, 0, 0)
GRAY = (50, 50, 50)

# Variabel Player
player_pos = [WIDTH//2, HEIGHT//2]
sanity = 100
flashlight_on = True

# Simulasi Hantu
ghost_pos = [random.randint(0, WIDTH), random.randint(0, HEIGHT)]
ghost_visible = False

running = True
clock = pygame.time.Clock()

while running:
    screen.fill(BLACK)
    
    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            running = False
        if event.type == pygame.KEYDOWN:
            if event.key == pygame.K_f:  # Tekan F untuk senter
                flashlight_on = not flashlight_on

    # Kontrol Player
    keys = pygame.key.get_pressed()
    if keys[pygame.K_w]: player_pos[1] -= 3
    if keys[pygame.K_s]: player_pos[1] += 3
    if keys[pygame.K_a]: player_pos[0] -= 3
    if keys[pygame.K_d]: player_pos[0] += 3

    # Logika Senter (Hanya memperlihatkan sekitar player)
    mouse_pos = pygame.mouse.get_pos()
    
    if flashlight_on:
        # Efek Senter (Lingkaran cahaya)
        pygame.draw.circle(screen, GRAY, player_pos, 150)
    
    # Render Player
    pygame.draw.circle(screen, WHITE, player_pos, 10)

    # Logika Hantu (Muncul jika Sanity rendah)
    distance_to_ghost = ((player_pos[0]-ghost_pos[0])**2 + (player_pos[1]-ghost_pos[1])**2)**0.5
    if distance_to_ghost < 100 and flashlight_on:
        ghost_visible = True
        sanity -= 0.5  # Sanity berkurang jika melihat hantu
    else:
        ghost_visible = False

    if ghost_visible:
        pygame.draw.circle(screen, RED, ghost_pos, 20) # Representasi hantu

    # UI Sanity
    pygame.draw.rect(screen, RED, (20, 20, sanity * 2, 20))
    
    if sanity <= 0:
        print("Karaktermu Gila! Game Over.")
        running = False

    pygame.display.flip()
    clock.tick(60)

pygame.quit()
