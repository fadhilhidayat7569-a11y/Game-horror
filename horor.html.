<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>Niskala Mobile Horor</title>
    <style>
        body { margin: 0; overflow: hidden; background: #000; font-family: sans-serif; touch-action: none; }
        canvas { display: block; }
        #ui {
            position: absolute; top: 10px; left: 10px; color: white;
            pointer-events: none; z-index: 10;
        }
        .bar { width: 150px; height: 10px; background: #333; border: 1px solid #fff; }
        #sanity-fill { width: 100%; height: 100%; background: red; }
        
        /* Kontrol HP */
        #controls {
            position: absolute; bottom: 30px; width: 100%;
            display: flex; justify-content: space-between; padding: 0 30px;
            box-sizing: border-box; align-items: center;
        }
        #joystick-area {
            width: 120px; height: 120px; background: rgba(255,255,255,0.1);
            border-radius: 50%; position: relative;
        }
        #joystick-stick {
            width: 50px; height: 50px; background: rgba(255,255,255,0.4);
            border-radius: 50%; position: absolute; top: 35px; left: 35px;
        }
        #action-btn {
            width: 70px; height: 70px; background: rgba(255,0,0,0.5);
            border-radius: 50%; color: white; display: flex;
            align-items: center; justify-content: center; font-weight: bold;
            border: 2px solid white; font-size: 12px;
        }
    </style>
</head>
<body>

<div id="ui">
    <div style="font-size: 12px;">SANITY</div>
    <div class="bar"><div id="sanity-fill"></div></div>
</div>

<div id="controls">
    <div id="joystick-area"><div id="joystick-stick"></div></div>
    <div id="action-btn">SENTER</div>
</div>

<canvas id="gameCanvas"></canvas>

<script>
const canvas = document.getElementById('gameCanvas');
const ctx = canvas.getContext('2d');
const stick = document.getElementById('joystick-stick');
const actionBtn = document.getElementById('action-btn');
const sanityFill = document.getElementById('sanity-fill');

canvas.width = window.innerWidth;
canvas.height = window.innerHeight;

let player = { x: canvas.width/2, y: canvas.height/2, sanity: 100 };
let flashlight = true;
let moveX = 0, moveY = 0;

// Joystick Logic
let joyStartX, joyStartY;
document.getElementById('joystick-area').addEventListener('touchstart', e => {
    joyStartX = e.touches[0].clientX;
    joyStartY = e.touches[0].clientY;
});

document.getElementById('joystick-area').addEventListener('touchmove', e => {
    let dx = e.touches[0].clientX - joyStartX;
    let dy = e.touches[0].clientY - joyStartY;
    let dist = Math.min(40, Math.sqrt(dx*dx + dy*dy));
    let angle = Math.atan2(dy, dx);
    
    let tx = Math.cos(angle) * dist;
    let ty = Math.sin(angle) * dist;
    
    stick.style.transform = `translate(${tx}px, ${ty}px)`;
    moveX = Math.cos(angle) * (dist/15);
    moveY = Math.sin(angle) * (dist/15);
});

document.getElementById('joystick-area').addEventListener('touchend', () => {
    stick.style.transform = `translate(0px, 0px)`;
    moveX = 0; moveY = 0;
});

// Senter Button
actionBtn.addEventListener('touchstart', (e) => {
    e.preventDefault();
    flashlight = !flashlight;
    actionBtn.style.background = flashlight ? "rgba(255,0,0,0.5)" : "rgba(50,50,50,0.5)";
});

// Hantu sederhana
let ghost = { x: Math.random()*canvas.width, y: Math.random()*canvas.height };

function loop() {
    ctx.fillStyle = "black";
    ctx.fillRect(0, 0, canvas.width, canvas.height);

    // Update Posisi
    player.x += moveX;
    player.y += moveY;

    // Gambar Hantu (Hanya terlihat jika dekat)
    let distToGhost = Math.sqrt((player.x-ghost.x)**2 + (player.y-ghost.y)**2);
    if(distToGhost < 150 && flashlight) {
        ctx.fillStyle = "white";
        ctx.beginPath();
        ctx.ellipse(ghost.x, ghost.y, 10, 25, 0, 0, Math.PI*2);
        ctx.fill();
        player.sanity -= 0.2;
    }

    // Efek Senter
    ctx.save();
    ctx.globalCompositeOperation = "destination-in";
    if(flashlight) {
        let grad = ctx.createRadialGradient(player.x, player.y, 20, player.x, player.y, 150);
        grad.addColorStop(0, "rgba(0,0,0,1)");
        grad.addColorStop(1, "rgba(0,0,0,0)");
        ctx.fillStyle = grad;
        ctx.beginPath();
        ctx.arc(player.x, player.y, 150, 0, Math.PI*2);
        ctx.fill();
    }
    ctx.restore();

    // Gambar Player
    ctx.fillStyle = "cyan";
    ctx.beginPath();
    ctx.arc(player.x, player.y, 8, 0, Math.PI*2);
    ctx.fill();

    sanityFill.style.width = player.sanity + "%";
    
    if(player.sanity > 0) requestAnimationFrame(loop);
    else alert("Game Over: Kamu gila karena ketakutan!");
}

loop();
</script>
</body>
</html>
